-- ============================================================
-- 4. PRODUTOS
-- ============================================================
CREATE TABLE produtos (
    id_produto INT PRIMARY KEY AUTO_INCREMENT,
    id_categoria INT NOT NULL,
    codigo_barras VARCHAR(20) UNIQUE NOT NULL,
    codigo_interno VARCHAR(20) UNIQUE,
    nome VARCHAR(150) NOT NULL,
    nome_fantasia VARCHAR(100),
    descricao TEXT,
    principio_ativo VARCHAR(100),
    concentracao VARCHAR(50),
    forma_farmaceutica VARCHAR(50),
    fabricante VARCHAR(100),
    registro_anvisa VARCHAR(20),
    preco_custo DECIMAL(10,2) NOT NULL,
    preco_venda DECIMAL(10,2) NOT NULL,
    margem_lucro DECIMAL(5,2),
    controlado BOOLEAN DEFAULT FALSE,
    tarja VARCHAR(20),
    lote VARCHAR(20),
    validade DATE,
    unidade_medida VARCHAR(10) DEFAULT 'UN',
    estoque_minimo INT DEFAULT 5,
    estoque_maximo INT DEFAULT 100,
    peso DECIMAL(10,3),
    dimensoes VARCHAR(50),
    similar_id INT,
    ativo BOOLEAN DEFAULT TRUE,
    data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP,
    data_atualizacao DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (id_categoria) REFERENCES categorias(id_categoria),
    FOREIGN KEY (similar_id) REFERENCES produtos(id_produto)
);

-- ============================================================
-- 5. ESTOQUE (por filial)
-- ============================================================
CREATE TABLE estoque (
    id_estoque INT PRIMARY KEY AUTO_INCREMENT,
    id_produto INT NOT NULL,
    id_filial INT NOT NULL,
    quantidade INT NOT NULL DEFAULT 0,
    quantidade_reservada INT DEFAULT 0,
    estoque_minimo INT DEFAULT 5,
    estoque_maximo INT DEFAULT 100,
    localizacao VARCHAR(50),
    prateleira VARCHAR(20),
    data_ultima_entrada DATETIME,
    data_ultima_saida DATETIME,
    data_atualizacao DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (id_produto) REFERENCES produtos(id_produto),
    FOREIGN KEY (id_filial) REFERENCES filiais(id_filial),
    UNIQUE KEY unique_produto_filial (id_produto, id_filial)
);

-- ============================================================
-- 6. FORNECEDORES
-- ============================================================
CREATE TABLE fornecedores (
    id_fornecedor INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    razao_social VARCHAR(150),
    cnpj VARCHAR(18) UNIQUE NOT NULL,
    inscricao_estadual VARCHAR(20),
    email VARCHAR(100) NOT NULL,
    telefone VARCHAR(20) NOT NULL,
    celular VARCHAR(20),
    endereco VARCHAR(200),
    numero VARCHAR(10),
    complemento VARCHAR(50),
    bairro VARCHAR(50),
    cidade VARCHAR(50),
    estado VARCHAR(2),
    cep VARCHAR(10),
    contato_nome VARCHAR(100),
    contato_cargo VARCHAR(50),
    contato_telefone VARCHAR(20),
    contato_email VARCHAR(100),
    ativo BOOLEAN DEFAULT TRUE,
    data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP,
    data_atualizacao DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- ============================================================
-- 7. CLIENTES
-- ============================================================
CREATE TABLE clientes (
    id_cliente INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    cpf VARCHAR(14) UNIQUE NOT NULL,
    rg VARCHAR(15),
    data_nascimento DATE,
    telefone VARCHAR(20) NOT NULL,
    celular VARCHAR(20),
    email VARCHAR(100),
    endereco VARCHAR(200),
    numero VARCHAR(10),
    complemento VARCHAR(50),
    bairro VARCHAR(50),
    cidade VARCHAR(50),
    estado VARCHAR(2),
    cep VARCHAR(10),
    id_convenio INT,
    numero_carteirinha VARCHAR(30),
    desconto_convenio DECIMAL(5,2) DEFAULT 0,
    credito_disponivel DECIMAL(10,2) DEFAULT 0,
    credito_limite DECIMAL(10,2) DEFAULT 0,
    ativo BOOLEAN DEFAULT TRUE,
    data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP,
    data_atualizacao DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (id_convenio) REFERENCES convenios(id_convenio)
);

-- ============================================================
-- 8. CONVÊNIOS
-- ============================================================
CREATE TABLE convenios (
    id_convenio INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    descricao TEXT,
    cnpj VARCHAR(18),
    telefone VARCHAR(20),
    email VARCHAR(100),
    desconto_padrao DECIMAL(5,2) DEFAULT 0,
    prazo_pagamento INT DEFAULT 30,
    ativo BOOLEAN DEFAULT TRUE,
    data_cadastro DATETIME DEFAULT CURRENT_TIMESTAMP
);

