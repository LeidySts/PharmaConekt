('Perfumaria', 'Perfumes e Fragrâncias', 'Perfumaria', '#fce4ec'),
('Suplementos e Vitaminas', 'Suplementos Alimentares e Vitaminas', 'Suplementos e Vitaminas', '#fff3e0'),
('Produtos para Bebês', 'Produtos Infantis e para Bebês', 'Produtos para Bebês', '#e0f7fa'),
('Curativos e Primeiros Socorros', 'Materiais para Curativos e Primeiros Socorros', 'Curativos e Primeiros Socorros', '#f3e5f5'),
